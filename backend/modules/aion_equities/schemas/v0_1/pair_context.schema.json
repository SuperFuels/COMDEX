{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aion://investing/schemas/pair_context.schema.json",
  "title": "AION Pair Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pair_context_id",
    "pair",
    "base_country_ref",
    "quote_country_ref",
    "as_of_date",
    "macro_coherence",
    "carry_signal",
    "risk_appetite_signal",
    "pair_score",
    "audit"
  ],
  "properties": {
    "pair_context_id": {
      "type": "string",
      "pattern": "^pair/[A-Z]{3}[A-Z]{3}/context/[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "pair": {
      "type": "string",
      "pattern": "^[A-Z]{3}[A-Z]{3}$"
    },
    "base_country_ref": {
      "type": "string",
      "pattern": "^country/[A-Z]{2}$"
    },
    "quote_country_ref": {
      "type": "string",
      "pattern": "^country/[A-Z]{2}$"
    },
    "as_of_date": {
      "type": "string",
      "format": "date"
    },
    "macro_coherence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "regime_alignment"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "regime_alignment": {
          "type": "string",
          "enum": ["supportive", "mixed", "contradictory", "unknown"]
        },
        "notes": { "type": "string" }
      }
    },
    "carry_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "strength"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["favour_base", "favour_quote", "neutral", "unwind_risk", "unknown"]
        },
        "strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "notes": { "type": "string" }
      }
    },
    "risk_appetite_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "confidence"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["risk_on", "risk_off", "transition", "unknown"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "notes": { "type": "string" }
      }
    },
    "pair_score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction_bias", "conviction"],
      "properties": {
        "direction_bias": {
          "type": "string",
          "enum": ["base_outperform", "quote_outperform", "range_bound", "unknown"]
        },
        "conviction": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "summary": { "type": "string" }
      }
    },
    "linked_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "country_ambassador_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^country/[A-Z]{2}$"
          }
        },
        "country_relationship_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^relationship/"
          }
        },
        "global_capital_markets_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^macro/global_capital_markets/"
          }
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "updated_at", "created_by"],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "updated_by": { "type": "string" }
      }
    }
  }
}