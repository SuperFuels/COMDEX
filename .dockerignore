# ─── Python venvs ───────────────────────────────────────────
.venv/
venv/

# ─── ignore only the repo-root env files ───────────────────
/.env
/.env.yaml

# ─── explicitly allow the backend folder and its .env ─────
!/backend
!/backend/.env

# ─── Git metadata ──────────────────────────────────────────
.git
.gitignore

# ─── Python bytecode ───────────────────────────────────────
__pycache__/
*.py[cod]

# ─── pip build artifacts ───────────────────────────────────
pip-wheel-metadata/

# ─── editor temp files ────────────────────────────────────
*.swp
.DS_Store
