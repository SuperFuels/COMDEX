# ─── Python venvs ───────────────────────────────────────────
.venv/
venv/

# ─── ignore only the repo-root env files ───────────────────
/.env
/env.yaml

# ─── but allow backend/.env into the build context ─────────
!backend/.env

# ─── Git metadata ──────────────────────────────────────────
.git
.gitignore

# ─── Python bytecode ───────────────────────────────────────
__pycache__/
*.py[cod]

# ─── pip build artifacts ───────────────────────────────────
pip-wheel-metadata/

# ─── editor temp files ────────────────────────────────────
*.swp
.DS_Store
