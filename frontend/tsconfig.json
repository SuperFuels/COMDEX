// /frontend/tsconfig.json
{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "preserve",

    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,

    "incremental": true,
    "types": ["next", "next/types", "react", "react-dom", "node"],

    /** ─────── Add these two so alias imports (e.g. "@/hooks/...") work ─────── */
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["components/*"],
      "@/hooks/*":      ["hooks/*"],
      "@/lib/*":        ["lib/*"],
      "@/utils/*":      ["utils/*"],
      "@/constants/*":  ["constants/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}