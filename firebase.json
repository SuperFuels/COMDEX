{
  "hosting": {
    // run these inside 'frontend'
    "predeploy": [
      "npm --prefix frontend ci",
      "npm --prefix frontend run build",
      "npm --prefix frontend run export"
    ],
    // serve the static-out folder
    "public": "frontend/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}

