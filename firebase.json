{
  "hosting": {
    // 1) run these inside 'frontend' before deploy
    "predeploy": [
      "npm --prefix frontend ci",
      "npm --prefix frontend run build",
      "npm --prefix frontend run export"
    ],
    // 2) point at your static output
    "public": "frontend/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    // 3) SPA‐style client‐side routing
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}

