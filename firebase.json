{
  "hosting": {
    // run these inside 'frontend'
    "predeploy": [
      "npm --prefix frontend ci",
      "npm --prefix frontend run build"
    ],
    // point at your static out folder
    "public": "frontend/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    // SPA‐style fallback
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}

