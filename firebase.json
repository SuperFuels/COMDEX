{
  "hosting": {
    "source": "frontend",
    "predeploy": [
      "npm ci",
      "npm run build",
      "npm run export"
    ],
    "public": "frontend/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}

