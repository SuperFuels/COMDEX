{
  "hosting": {
    "source": "frontend",
    "predeploy": [
      "npm ci",
      "npm run build",
      "npm run export"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}

